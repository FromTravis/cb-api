# Copy this file to .env and fill in your values.
# .env is gitignored — never commit your actual keys.
# On Railway, set these as environment variables in the project settings.

# FRED API key — free at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_key_here

# Anthropic API key — https://console.anthropic.com
# Used to summarise Fed statements with Claude Haiku
ANTHROPIC_API_KEY=your_anthropic_key_here

# Optional: set to 1 to enable Flask debug mode (local dev only)
FLASK_DEBUG=0

# Optional: port (default 5000, Railway sets this automatically)
# PORT=5000
